{
  "name": "bizquery-copilotkit-runtime",
  "version": "1.0.0",
  "description": "CopilotKit Runtime middleware for BizQuery — bridges the React frontend with Bedrock AgentCore Runtime",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "3.758.0",
    "@copilotkit/runtime": "1.8.14",
    "cors": "2.8.5",
    "dotenv": "^17.4.2",
    "express": "4.21.2",
    "jsonwebtoken": "9.0.2",
    "jwks-rsa": "3.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "globals": {
      "ts-jest": {
        "isolatedModules": true
      }
    }
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.1",
    "@types/jest": "29.5.13",
    "@types/jsonwebtoken": "9.0.9",
    "@types/node": "22.13.10",
    "@types/supertest": "6.0.2",
    "jest": "29.7.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.6",
    "ts-node": "10.9.2",
    "typescript": "5.8.2"
  }
}
